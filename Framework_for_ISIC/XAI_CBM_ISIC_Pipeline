  print(\"INITIALIZING PHASE 6: OOD MICRO-BATCH ACID TEST...\")\n","\n","    # 1. Cloud Architecture Paths\n","    DATA_DIR = \"/content/drive/MyDrive/XAI_Cloud_Run/isic_2020/\"\n","    META_CSV = os.path.join(DATA_DIR, \"train.csv\")\n","    IMAGE_DIR = os.path.join(DATA_DIR, \"images\")\n","    CHECKPOINT_DIR = \"/content/drive/MyDrive/XAI_Cloud_Run/cloud_checkpoints/\"\n","    CKPT_PATH = os.path.join(CHECKPOINT_DIR, \"ham-gated-cbm-epoch=20-val_auc=0.950.ckpt\")\n","\n","    if not os.path.exists(IMAGE_DIR) or not os.path.exists(META_CSV):\n","        print(f\"Missing Data: Ensure train.csv and the images folder are in {DATA_DIR}\")\n","        return\n","\n","    # 2. Boot the Engine\n","    print(\"Booting Release Candidate 1 in Evaluation Mode...\")\n","    base_model = GatedHybridCBM(\n","        concept_dims=Config.get_active_concept_dims(),\n","        backbone=Config.BACKBONE,\n","        feat_proj_dim=Config.FEAT_PROJ_DIM,\n","        hidden=Config.HIDDEN_DIM,\n","        dropout=Config.DROPOUT\n","    )\n","\n","    system = CBM_System.load_from_checkpoint(CKPT_PATH, model=base_model, config=Config)\n","    system.eval()\n","\n","    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n","    system.to(device)\n","    print(f\"Processing on: {device}\")\n","\n","    # 3. The Reverse-Lookup Data Mapper\n","    print(\"Mapping specific uploaded images to ISIC 2020 Ground Truth...\")\n","    df = pd.read_csv(META_CSV)\n","\n","    # Get a list of the exact images you actually uploaded to Drive\n","    uploaded_files = [f for f in os.listdir(IMAGE_DIR) if f.endswith(('.jpg', '.jpeg', '.png'))]\n","    uploaded_basenames = [os.path.splitext(f)[0] for f in uploaded_files]\n","\n","    # Filter the massive CSV to ONLY include the 30 images you uploaded\n","    test_df = df[df['image_name'].isin(uploaded_basenames)].reset_index(drop=True)\n","    total_imgs = len(test_df)\n","\n","    if total_imgs == 0:\n","        print(\"CRITICAL FAULT: None of the uploaded image names matched the 'image_name' column in train.csv.\")\n","        return\n","\n","    print(f\"Target Locked: Identified ground truth for {total_imgs} images.\")\n","\n","    transform = transforms.Compose([\n","        transforms.Resize((224, 224)),\n","        transforms.ToTensor()\n","    ])\n","\n","    # 4. Telemetry Storage\n","    y_true = []\n","    y_probs = []\n","    alpha_history = []\n","\n","    # 5. The Execution Loop\n","    print(\"\\nExecuting Neural Forward Passes...\")\n","    with torch.no_grad():\n","        for _, row in tqdm(test_df.iterrows(), total=total_imgs, desc=\"Auditing\"):\n","            img_name = str(row['image_name']) + \".jpg\"\n","            img_path = os.path.join(IMAGE_DIR, img_name)\n","\n","            try:\n","                # Ingest\n","                image = Image.open(img_path).convert(\"RGB\")\n","                img_tensor = transform(image).unsqueeze(0).to(device)\n","\n","                # Unison Pass\n","                _, y_logit, alpha = system(img_tensor)\n","\n","                # Extract Telemetry\n","                melanoma_prob = torch.sigmoid(y_logit).item()\n","                alpha_val = alpha.item()\n","\n","                y_true.append(row['target'])\n","                y_probs.append(melanoma_prob)\n","                alpha_history.append(alpha_val)\n","\n","            except Exception as e:\n","                print(f\"Error processing {img_name}: {e}\")\n","\n","    # 6. Mathematical Audit\n","    print(\"\\n\" + \"=\"*50)\n","    print(\"MICRO-BATCH OOD ACID TEST REPORT:\")\n","    print(\"=\"*50)\n","\n","    # Check if we have at least one of each class to calculate AUC safely\n","    if len(set(y_true)) > 1:\n","        ood_auc = roc_auc_score(y_true, y_probs)\n","        print(f\"OOD AUC Score: {ood_auc:.3f}\")\n","    else:\n","        print(\"OOD AUC Score: N/A (Cannot calculate AUC; all 30 images belonged to the same class).\")\n","\n","    y_pred = [1 if p > 0.5 else 0 for p in y_probs]\n","    print(\"-\" * 50)\n","    print(\"Standard Classification Metrics (0.5 Threshold):\")\n","    # Wrap target_names dynamically in case the micro-batch is missing a class\n","    labels_present = list(set(y_true))\n","    target_names = [[\"Benign\", \"Melanoma\"][i] for i in sorted(labels_present)]\n","    try:\n","        print(classification_report(y_true, y_pred, target_names=target_names, labels=sorted(labels_present)))\n","    except Exception as e:\n","        print(f\"Classification report error: {e}\")\n","\n","    avg_alpha = np.mean(alpha_history)\n","    print(\"-\" * 50)\n","    print(\"XAI ROUTING INTEGRITY (ALPHA GATE):\")\n","    print(f\"Average Alpha Reliance: {avg_alpha:.3f} (Ideal: > 0.500)\")\n","    print(f\"Black-Box Bias (<0.2): {sum(1 for a in alpha_history if a < 0.2) / len(alpha_history) * 100:.1f}%\")\n","    print(f\"Pure Concept Logic (>0.8): {sum(1 for a in alpha_history if a > 0.8) / len(alpha_history) * 100:.1f}%\")\n","    print(\"=\"*50)\n","\n","# Execute\n","run_micro_acid_test()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":711,"referenced_widgets":["77b9a3b6408c4baeb6c9161ed26a6c63","e83d66f509ee48ff98212d59db521a36","adbc29cc12f2412084d3b6a1c26621af","25e3e53fe8f64c73b6213f159768bb5c","f14475dea13541eaaea8190dbec740a6","d84f68ec3bb5485896177333a00183c5","2fe147aabcf24747ae36f5a1e54e0402","c3ab573bc5fb4179b2343e6c61643152","2f20ac16a08247aa8c9bdfab13d41527","ab8d577e60b046dc8a2cced33fea5eaa","63e7b376556b484c97e8d2f8bc5a247e"]},"id":"Ao2nJvFhzb2u","executionInfo":{"status":"ok","timestamp":1780395160842,"user_tz":-330,"elapsed":55136,"user":{"displayName":"Parun Sethupathy","userId":"09834226717703590864"}},"outputId":"c97fb7ab-3511-4410-8e7f-1de0186c1de7"},"execution_count":7,"outputs":[{"output_type":"stream","name":"stdout","text":["INITIALIZING PHASE 6: OOD MICRO-BATCH ACID TEST...\n","Booting Release Candidate 1 in Evaluation Mode...\n"]},{"output_type":"stream","